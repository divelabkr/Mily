{
  "expo": {
    "name": "Mily - 가족 소비 회고",
    "slug": "mily",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mily",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF8"
    },
    "ios": {
      "bundleIdentifier": "com.mily.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "주간 회고 알림과 가족 요청 카드 알림을 위해 필요합니다.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.mily.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#FAFAF8",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#F4A261",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "mily"
      }
    },
    "description": "미루지 않는 경제 대화, Mily. 용돈 협상부터 소비 회고까지, 가족이 함께하는 주 1회 5분 소비 회고 앱.",
    "keywords": ["가계부", "소비", "가족", "회고", "예산", "청소년"],
    "primaryColor": "#F4A261",
    "owner": "mily-team"
  }
}
